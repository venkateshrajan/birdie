# Admin access — set a strong value on the VPS
ADMIN_PASSWORD=change-me-to-something-long

# iron-session cookie encryption — must be >= 32 chars, random
# generate with: openssl rand -base64 36
SESSION_SECRET=generate-a-32-plus-char-random-string-here

# Where the SQLite file lives (persistent path on the VPS)
DATABASE_PATH=/var/lib/birdie/birdie.db

# Splitwise (chat feature) — used by the vendored MCP server
SPLITWISE_GROUP_NAME=Fireboys Badminton
SPLITWISE_API_KEY=get-from-secure.splitwise.com/apps

# Anthropic API — enables "Add session from a Playo screenshot" in /admin.
# Optional: if unset, the 📷 screenshot button is hidden. Get a key from
# console.anthropic.com. Vision on one screenshot is a fraction of a rupee.
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-haiku-4-5 (vision-capable, cheap).
# BIRDIE_VISION_MODEL=claude-haiku-4-5
